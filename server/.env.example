# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DB_NAME=phishguard_pds

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Threat Intelligence APIs (optional) ──────────────────────────────────────
# Get free key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# Get free key at: https://console.cloud.google.com → Safe Browsing API
GOOGLE_SAFE_BROWSING_KEY=

# ── Email Alerts (optional, Gmail example) ───────────────────────────────────
SMTP_FROM=alerts@yourdomain.com
SMTP_ALERT_TO=admin@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
